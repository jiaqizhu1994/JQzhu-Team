  "researchAreas": [
    {
      "title": "动态视觉智能传感芯片",
      "description": "面向高速运动探测与复杂动态场景感知，开展新型动态视觉智能传感芯片研究。通过融合事件驱动成像、超快光电响应与片上智能处理，实现对光强变化信息的低延迟、高时间分辨和低冗余获取，为高速目标识别、运动感知及智能视觉系统提供高性能芯片基础。",
      "tags": [
        "Dynamic Vision Sensor",
        "Neuromorphic Vision",
        "Intelligent Sensing Chip"
      ],
      "image": "/uploads/ChatGPT-Image-2026-7-20-18_27_29-1784543279947.png",
      "images": [
        "/uploads/ChatGPT-Image-2026-7-20-18_27_29-1784543279947.png"
      ],
      "href": "#contact",
      "accent": "from-blue-50 via-cyan-50 to-white"
    },
    {
      "title": "动态视觉智能感知算法",
      "description": "面向动态视觉传感器产生的异步事件流数据，开展事件信息表征、时空特征提取与多模态视觉融合算法研究。通过结合深度学习、脉冲神经网络与事件帧协同处理，实现高速运动目标的精准识别、跟踪与场景理解，充分发挥动态视觉低延迟、高动态范围和高时间分辨率的优势。",
      "tags": [
        "Event-Based Vision",
        "Spatiotemporal Learning",
        "Multimodal Fusion"
      ],
      "image": "/uploads/ChatGPT-Image-2026-7-20-18_38_55-1784543961091.png",
      "href": "#contact",
      "accent": "from-blue-50 via-cyan-50 to-white",
      "images": [
        "/uploads/ChatGPT-Image-2026-7-20-18_38_55-1784543961091.png"
      ]
    },
    {
      "title": "新型光电传感材料生长",
      "description": "面向高性能光电探测与智能传感器件需求，开展基于分子束外延技术的新型光电材料生长研究。依托超高真空生长与原位表征平台，实现薄膜厚度、组分、界面及缺陷的精确调控，构筑高质量半导体薄膜与异质结结构，为高灵敏、宽光谱和高速光电传感器件提供材料基础。",
      "tags": [
        "Molecular Beam Epitaxy",
        "Optoelectronic Materials",
        "Heterostructure Engineering"
      ],
      "image": "/uploads/ChatGPT-Image-2026-7-20-18_42_10-1784544164383.png",
      "href": "#contact",
      "accent": "from-sky-50 via-indigo-50 to-white",
      "images": [
        "/uploads/ChatGPT-Image-2026-7-20-18_42_10-1784544164383.png"
      ]
    },
    {
      "title": "片上集成光谱芯片",
      "description": "面向便携式光谱检测与智能化物质识别需求，开展微型化片上集成光谱芯片研究。通过融合光子集成、微纳光学调控与智能光谱重构，实现光谱信息的高效分光、快速采集与精准解析，突破传统光谱仪体积大、结构复杂等限制，为环境监测、生物检测及智能感知提供小型化、高集成度的光谱解决方案。",
      "tags": [
        "Integrated Spectroscopy",
        "Photonic Integration",
        "Spectral Reconstruction"
      ],
      "image": "/uploads/ChatGPT-Image-2026-7-20-18_45_05-1784544321673.png",
      "href": "#contact",
      "accent": "from-emerald-50 via-cyan-50 to-white",
      "images": [
        "/uploads/ChatGPT-Image-2026-7-20-18_45_05-1784544321673.png"
      ]
    }
